generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Organization {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  customers     Customer[]
  events        Event[]            @relation("OrganizationEvents")
  leads         Lead[]
  projects      Project[]
  transactions  Transaction[]      @relation("OrganizationTransactions")
  messages      Message[]          @relation("OrganizationMessages")
  campaigns     Campaign[]         @relation("OrganizationCampaigns")
  users         User[]             @relation("OrganizationUsers")
  autoReplies   AutoReplyRule[]
  scheduled     ScheduledMessage[]
  conversations SalesConversation[]
  aiConfig      AiAgentConfig?     @relation("OrganizationAiConfig")
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  password       String
  name           String?
  role           String       @default("VIEWER")
  organizationId String
  consentGiven   Boolean      @default(false)
  consentDate    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tasks          TaskCard[]
  organization   Organization @relation("OrganizationUsers", fields: [organizationId], references: [id])
}

model Lead {
  id             String      @id @default(cuid())
  name           String
  phone          String      @unique
  email          String?
  status         String      @default("NOVO")
  score          Int         @default(0)
  tags           String?     // Tags separadas por vírgula
  consentGiven   Boolean     @default(false)
  consentDate    DateTime?
  lastInteraction DateTime   @default(now())
  
  aiEnabled      Boolean     @default(true)
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  messages       Message[]     @relation("LeadMessages")
  opportunities  Opportunity[]
  scheduled      ScheduledMessage[]
  conversations  SalesConversation[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model SalesConversation {
  id             String      @id @default(cuid())
  etapa          String      @default("inicio") // inicio, qualificacao, proposta, negociacao, captura_lead, fechamento
  dados          String      @default("{}")     // Histórico e metadados em JSON
  lastOutcome    String      @default("pending") // pending, success, failure
  
  leadId         String
  lead           Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model AutoReplyRule {
  id             String      @id @default(cuid())
  trigger        String      // Keyword ou Regex
  response       String      @map("response") // Texto da resposta
  matchType      String      @default("KEYWORD") // KEYWORD, REGEX, CONTAINS
  isActive       Boolean     @default(true)
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model ScheduledMessage {
  id             String      @id @default(cuid())
  content        String
  sendAt         DateTime
  status         String      @default("PENDING") // PENDING, SENT, FAILED, CANCELLED
  
  leadId         String
  lead           Lead        @relation(fields: [leadId], references: [id])
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  text           String
  sender         String       @default("me") // "me" (usuário do CRM) ou "lead" (cliente)
  leadId         String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lead           Lead         @relation("LeadMessages", fields: [leadId], references: [id], onDelete: Cascade)
  organization   Organization @relation("OrganizationMessages", fields: [organizationId], references: [id])
}

model Opportunity {
  id          String     @id @default(cuid())
  title       String
  value       Float      @default(0)
  stage       String     @default("CONTATO INICIAL")
  priority    String     @default("ENTRADA")
  statusBadge String?
  leadId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  lead        Lead       @relation(fields: [leadId], references: [id])
  tasks       TaskCard[]
}

model Project {
  id             String       @id @default(cuid())
  name           String
  progress       Int          @default(0)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  columns        Column[]
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Column {
  id        String     @id @default(cuid())
  title     String
  order     Int
  projectId String
  project   Project    @relation(fields: [projectId], references: [id])
  cards     TaskCard[]
}

model TaskCard {
  id            String       @id @default(cuid())
  title         String
  description   String?
  progress      Int          @default(0)
  priority      String       @default("NORMAL")
  date          String?
  columnId      String
  opportunityId String?
  userId        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User?        @relation(fields: [userId], references: [id])
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  column        Column       @relation(fields: [columnId], references: [id])
}

model Customer {
  id             String         @id @default(cuid())
  name           String
  domain         String?
  mrr            Float          @default(0)
  ltv            Float          @default(0)
  status         String         @default("ATIVO")
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  subscriptions  Subscription[]
}

model Subscription {
  id         String   @id @default(cuid())
  plan       String
  status     String
  price      Float
  customerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Event {
  id             String       @id @default(cuid())
  title          String
  description    String?
  start          DateTime
  end            DateTime?
  color          String?      @default("bg-primary")
  priority       String?      @default("NORMAL")
  location       String?
  reminderSent   Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation("OrganizationEvents", fields: [organizationId], references: [id])
}

model Transaction {
  id             String       @id @default(cuid())
  description    String
  amount         Float
  type           String       @default("INCOME")
  category       String?
  date           DateTime     @default(now())
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation("OrganizationTransactions", fields: [organizationId], references: [id])
}

model Campaign {
  id             String        @id @default(cuid())
  name           String
  message        String
  status         String        @default("PENDING") // PENDING, PROCESSING, PAUSED, COMPLETED, FAILED
  totalContacts  Int           @default(0)
  processedCount Int           @default(0)
  successCount   Int           @default(0)
  failedCount    Int           @default(0)
  targetTags     String?       // Tags de alvo separadas por vírgula
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation("OrganizationCampaigns", fields: [organizationId], references: [id])
  logs           CampaignLog[]
}

model CampaignLog {
  id         String   @id @default(cuid())
  campaignId String
  phone      String
  status     String   // SENT, FAILED, INVALID_NUMBER
  error      String?
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model AiAgentConfig {
  id             String       @id @default(cuid())
  name           String       @default("JARVIS")
  temperament    String       @default("Profissional, direto e solícito.")
  bio            String?      @default("Especialista em vendas e suporte da empresa.")
  products       String?      @default("Consultar catálogo principal.")
  active         Boolean      @default(true)
  
  organizationId String       @unique
  organization   Organization @relation("OrganizationAiConfig", fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
